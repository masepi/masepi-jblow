		"checkbox.border": "#b59e7a",
		"debugExceptionWidget.border": "#b59e7a",
		"debugToolBar.border": "#b59e7a",
		"dropdown.background": "#2a343e",
		"dropdown.border": "#b59e7a",
		"dropdown.listBackground": "#042327",
		"editor.background": "#062626",
